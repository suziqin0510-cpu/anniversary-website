// 照片数据接口定义
interface Photo {
  id: string;
  url: string;
  caption: string;
}

interface Chapter {
  id: string;
  number: string;
  title: string;
  subtitle: string;
  date: string;
  location: string;
  story: string;
  quote: string;
  highlights: string[];
  tags: string[];
  photos: Photo[];
  hiddenMessage: string;
}

